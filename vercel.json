{
  "functions": {
    "pages/api/quotes.js": { "maxDuration": 30 },
    "pages/api/analysis.js": { "maxDuration": 60 }
  },
  "regions": ["icn1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
